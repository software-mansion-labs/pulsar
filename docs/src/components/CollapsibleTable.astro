---
interface Props {
  headers: string[];
  rows: string[][];
  initialRows?: number;
}

const { headers, rows, initialRows = 5 } = Astro.props;
const hasMore = rows.length > initialRows;
const id = `table-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="collapsible-table">
  <table>
    <thead>
      <tr>
        {headers.map((h) => <th>{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class={i >= initialRows ? `${id}-extra hidden` : ''}>
          {row.map((cell) => <td><code>{cell}</code></td>)}
        </tr>
      ))}
    </tbody>
  </table>
  {hasMore && (
    <button
      class="show-more-btn"
      data-target={id}
      data-label-more={`Show ${rows.length - initialRows} more`}
      data-label-less="Show less"
    >
      Show {rows.length - initialRows} more
    </button>
  )}
</div>

<style>
  .collapsible-table {
    margin-bottom: 1rem;
  }
  .hidden {
    display: none;
  }
  .show-more-btn {
    padding: 0.35rem 0.85rem 0.3rem 0.85rem;
    font-size: 0.85rem;
    font-weight: bold;
    border: 1px solid var(--color-primary);
    border-radius: 4px;
    background: transparent;
    color: var(--color-primary);
    cursor: pointer;
  }
  .show-more-btn:hover {
    background: var(--color-primary-light);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.show-more-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.target!;
      const extras = document.querySelectorAll<HTMLElement>(`.${id}-extra`);
      const expanded = !extras[0]?.classList.contains('hidden');
      extras.forEach((row) => row.classList.toggle('hidden', expanded));
      btn.textContent = expanded ? btn.dataset.labelMore! : btn.dataset.labelLess!;
    });
  });
</script>
